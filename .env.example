# GeoAdmin environment variables — copy to .env.local and fill in real values.
# NEVER commit real secrets. Only NEXT_PUBLIC_* values are exposed to the browser.

# ── Supabase (public — safe in the client bundle) ────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
# Canonical app origin, used to build invite/reset links (must be set in production)
NEXT_PUBLIC_APP_URL=https://geoadmin.ge

# ── Server-only secrets (NEVER expose / NEVER prefix with NEXT_PUBLIC_) ───────
# Service role key = full DB access, bypasses RLS. Server runtime only.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
# High-entropy random string; Vercel Cron sends it as `Authorization: Bearer <CRON_SECRET>`.
# If unset, the trash-cleanup cron fails closed (no deletes).
CRON_SECRET=generate-a-long-random-string

# ── Resend (transactional email) ─────────────────────────────────────────────
RESEND_API_KEY=your-resend-api-key
RESEND_FROM_EMAIL=noreply@geoadmin.ge
RESEND_FROM_NAME=GeoAdmin
